<!DOCTYPE html>
<!-- このページはHTML5です、という宣言 -->

<html>
  <!-- ページ全体の開始 -->

  <head>
    <!-- 画面には表示されない設定エリア -->

    <!-- スマホでもきれいに表示するための設定 -->
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- model-viewer（3D表示機能）を読み込む -->
    <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

    <!-- ページタイトル（タブに表示される） -->
    <title>demoA 3Dビュー</title>
  </head>

  <body style="margin:0; background:#f5f5f5;">
    <!-- 実際に画面に表示されるエリア -->
    <!-- margin:0 → 余白を消す / background → 背景色 -->

    <!-- タイトル表示 -->
    <div style="position:absolute; top:10px; left:10px; z-index:1;">
      <h2 style="margin:0;">demoA</h2>
      <p style="margin:0; font-size:14px;">
        指で回転・ピンチで拡大・AR表示も可能
      </p>
    </div>

    <!-- ここが3Dモデル表示の本体 -->
    <model-viewer 

      src="demoA.glb"
      <!-- 表示する3Dモデル（同じフォルダに置く） -->

      ar
      <!-- AR機能を有効化（スマホでボタン表示） -->

      auto-rotate
      <!-- モデルを自動でゆっくり回転させる -->

      camera-controls
      <!-- 指で回転・ズーム操作を可能にする -->

      environment-image="neutral"
      <!-- 光の当たり方を自然にする（見た目改善） -->

      style="width: 100%; height: 100vh;">
      <!-- 画面いっぱいに表示 -->

    </model-viewer>

  </body>
</html>
